<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.GUI.Avalonia.Dialogs.SelectionDialog"
        Title="CKAN - Select"
        Width="450" Height="350"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Name="MessageText" TextWrapping="Wrap"
                   FontSize="14" Margin="0,0,0,8" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Click="OnOkClick" Classes="accent" />
            <Button Content="Cancel" Width="80" Click="OnCancelClick" />
        </StackPanel>

        <ListBox Name="OptionsList" SelectionMode="Single" />
    </DockPanel>
</Window>
