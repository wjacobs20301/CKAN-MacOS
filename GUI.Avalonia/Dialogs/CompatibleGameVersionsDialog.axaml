<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.GUI.Avalonia.Dialogs.CompatibleGameVersionsDialog"
        Title="Compatible Game Versions"
        Width="400" Height="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Click="OnOkClick" Classes="accent" />
            <Button Content="Cancel" Width="80" Click="OnCancelClick" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Name="CurrentVersionText" FontWeight="SemiBold" />
            <TextBlock Text="Select additional compatible game versions:" />
            <ListBox Name="VersionList" SelectionMode="Multiple,Toggle" />
        </StackPanel>
    </DockPanel>
</Window>
