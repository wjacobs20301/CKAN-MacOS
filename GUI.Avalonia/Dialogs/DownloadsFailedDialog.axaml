<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.GUI.Avalonia.Dialogs.DownloadsFailedDialog"
        Title="Downloads Failed"
        Width="500" Height="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="Retry" Width="80" Click="OnRetryClick" Classes="accent" />
            <Button Content="Skip" Width="80" Click="OnSkipClick" />
            <Button Content="Cancel" Width="80" Click="OnCancelClick" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="The following downloads failed:" FontWeight="SemiBold" />
            <ListBox Name="FailedList" />
        </StackPanel>
    </DockPanel>
</Window>
