<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.GUI.Avalonia.Dialogs.ErrorDialog"
        Title="CKAN - Error"
        Width="560" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="OpenLogButton" Content="Open log folder" Click="OnOpenLogClick" />
            <Button Name="CopyButton" Content="Copy details" Click="OnCopyClick" />
            <Button Content="OK" Width="80" Click="OnOkClick" Classes="accent" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Name="ErrorText" TextWrapping="Wrap" FontSize="14"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
            <Expander Name="DetailsExpander" Header="Details" IsExpanded="False"
                      IsVisible="False">
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8"
                        MaxHeight="180">
                    <ScrollViewer>
                        <TextBlock Name="DetailsText" TextWrapping="Wrap"
                                   FontFamily="Menlo,Consolas,monospace" FontSize="11" />
                    </ScrollViewer>
                </Border>
            </Expander>
        </StackPanel>
    </DockPanel>
</Window>
