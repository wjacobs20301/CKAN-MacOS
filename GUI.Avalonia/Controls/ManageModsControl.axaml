<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CKAN.GUI.Avalonia.ViewModels"
             xmlns:controls="using:CKAN.GUI.Avalonia.Controls"
             x:Class="CKAN.GUI.Avalonia.Controls.ManageModsControl">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="350" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- Left: Mod List -->
        <DockPanel Grid.Column="0">
            <!-- Search Bar -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Right" Text="{Binding ModCountText}"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBox Watermark="Search mods..."
                         Text="{Binding SearchText}" />
            </DockPanel>

            <!-- Mod DataGrid -->
            <DataGrid ItemsSource="{Binding FilteredMods}"
                      SelectedItem="{Binding SelectedMod}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Inst."
                                            Binding="{Binding IsInstallChecked}"
                                            Width="50" />
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="200" />
                    <DataGridTextColumn Header="Author"
                                        Binding="{Binding AuthorsString}"
                                        Width="120" />
                    <DataGridTextColumn Header="Installed"
                                        Binding="{Binding InstalledVersion}"
                                        Width="90" />
                    <DataGridTextColumn Header="Latest"
                                        Binding="{Binding LatestVersion}"
                                        Width="90" />
                    <DataGridTextColumn Header="Compat."
                                        Binding="{Binding GameCompatibility}"
                                        Width="80" />
                    <DataGridTextColumn Header="DL Size"
                                        Binding="{Binding DownloadSize}"
                                        Width="70" />
                    <DataGridTextColumn Header="Inst. Size"
                                        Binding="{Binding InstallSize}"
                                        Width="70" />
                    <DataGridTextColumn Header="Downloads"
                                        Binding="{Binding DownloadCount}"
                                        Width="80" />
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Abstract}"
                                        Width="*" />
                </DataGrid.Columns>

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Install" />
                        <MenuItem Header="Uninstall" />
                        <MenuItem Header="Reinstall" />
                        <Separator />
                        <MenuItem Header="Update" />
                        <Separator />
                        <MenuItem Header="Download Contents" />
                        <MenuItem Header="Purge Cached Downloads" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

        <!-- Right: Mod Info Panel -->
        <controls:ModInfoControl Grid.Column="2"
                                  DataContext="{Binding ModInfoViewModel}" />
    </Grid>
</UserControl>
