<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CKAN.GUI.Avalonia.ViewModels"
             x:Class="CKAN.GUI.Avalonia.Controls.PlayTimeControl"
             x:DataType="vm:PlayTimeViewModel">

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Play Time" FontSize="18"
                   FontWeight="Bold" Margin="0,0,0,8" />
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding TotalPlayTime}"
                   FontWeight="SemiBold" Margin="0,8,0,0" />

        <DataGrid x:CompileBindings="False"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Instance" Binding="{Binding InstanceName}" Width="*" />
                <DataGridTextColumn Header="Play Time" Binding="{Binding PlayTime}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
